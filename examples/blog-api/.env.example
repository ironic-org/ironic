# JWT secret — change this in production
JWT_SECRET=ironic-dev-secret

# Redis cache (optional — remove or leave blank for InMemory)
# BLOG_REDIS_URL=redis://localhost:6379

# Server config
SERVER_HOST=127.0.0.1
SERVER_PORT=3000

# CORS origins (JSON array)
CORS_ORIGINS=["*"]

# Rate limit (requests per minute)
RATE_LIMIT_MAX=100
