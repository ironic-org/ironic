# Server
SERVER_HOST=127.0.0.1
SERVER_PORT=3000

# Logging
RUST_LOG=info

# Security
# Comma-separated origins allowed; leave empty to deny all cross-origin requests
CORS_ORIGINS=
# Maximum requests per IP per 60-second window
RATE_LIMIT_MAX=100

# Database (uncomment to use)
# DATABASE_URL=postgres://user:CHANGE_ME@localhost:5432/mydb

# Redis (uncomment to use)
# REDIS_URL=redis://localhost:6379
