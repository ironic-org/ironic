# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=3000

# Logging
RUST_LOG=info,todo-example=debug

# Security
CORS_ORIGINS=[]
RATE_LIMIT_MAX=100

# Database
DATABASE_URL=postgres://user:CHANGE_ME@localhost:5432/todo-example
DB_POOL_SIZE=10

# Redis (for caching and sessions)
REDIS_URL=redis://localhost:6379
